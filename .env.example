# .env.example — Bastion v3 secrets template
# Copy to .env and fill in your values: cp .env.example .env
# NEVER commit .env to git. This file (.env.example) is safe to commit.
# All non-secret config belongs in bastion.toml, NOT here.

# ── LLM Provider API Keys ─────────────────────────────────────────────────────
# Provide at least one. ANTHROPIC_API_KEY is the default provider.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-...
GROQ_API_KEY=gsk_...

# ── Messaging Channels ────────────────────────────────────────────────────────
# Telegram (recommended) — from @BotFather via /newbot
TELEGRAM_BOT_TOKEN=1234567890:ABC...
TELEGRAM_USER_ID=

# Discord — from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_USER_ID=

# Slack — from https://api.slack.com/apps
SLACK_BOT_TOKEN=
SLACK_USER_ID=

# WhatsApp via Evolution API — https://doc.evolution-api.com
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_NUMBER=

# ── Internal Auth ─────────────────────────────────────────────────────────────
# Random 32+ char string — authenticates Python MCP skill servers to /api/infer
# Generate: openssl rand -hex 32
BASTION_INFER_TOKEN=your-secret-token-here

# ── Container User (optional) ─────────────────────────────────────────────────
# Defaults to 1000:1000. Override if your system user has a different UID/GID.
# Run: id -u && id -g  to find your UID/GID
# BASTION_UID=1000
# BASTION_GID=1000

# ── Runtime Identity (set automatically by installer.sh) ─────────────────────
# UID/GID of the host user so container files are never owned by root
BASTION_UID=1000
BASTION_GID=1000

# Timezone for all date/time operations (e.g. calendar, agenda, scheduling)
# Detected from system by installer. Change to any IANA zone (e.g. America/Sao_Paulo)
TIMEZONE=UTC

# ── TOTP Authentication ───────────────────────────────────────────────────────
# Generated during onboarding via pyotp.random_base32()
# NEVER commit the real value — copy this file to .env and fill in
BASTION_TOTP_SECRET=

# Session duration in hours after successful TOTP authentication
BASTION_SESSION_TTL_HOURS=8

# Maximum failed TOTP attempts before session is blocked
BASTION_MAX_AUTH_ATTEMPTS=3

# ── Database Strategy ─────────────────────────────────────────────────────────
# Options: sqlite | supabase
DB_STRATEGY=sqlite

# Path to SQLite database file (used when DB_STRATEGY=sqlite)
SQLITE_PATH=./db/life-log.db

# Supabase credentials (used when DB_STRATEGY=supabase)
SUPABASE_URL=
SUPABASE_KEY=

# ── Composio ─────────────────────────────────────────────────────────────────
# Consumer key para integração com 850+ apps via Composio
# Crie sua chave em: https://dashboard.composio.dev
COMPOSIO_CONSUMER_KEY=

# ── Runtime overrides (optional) ──────────────────────────────────────────────
# Non-secret runtime config now lives in bastion.toml (D-09). Any value there can
# be overridden via a BASTION__SECTION__KEY env var (config crate, "__" separator),
# e.g. BASTION__AGENT__DEFAULT_MODEL=claude-opus-4-7. Secrets stay here in .env only.

# ── Webhook (optional — disabled by default) ─────────────────────────────────
# Only needed if channels.webhook.enabled = true in bastion.toml
# BASTION_WEBHOOK_ADDR=0.0.0.0:8080
